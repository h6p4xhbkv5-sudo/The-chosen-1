{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/config", "dest": "/api/supabase-auth.js" },
    { "src": "/api/(.*)", "dest": "/api/$1.js" },
    { "src": "/pricing", "dest": "/pricing.html" },
    { "src": "/admin", "dest": "/admin.html" },
    { "src": "/privacy", "dest": "/privacy-policy.html" },
    { "src": "/terms", "dest": "/terms.html" },
    { "src": "/cookies", "dest": "/cookies.html" },
    { "src": "/contact", "dest": "/contact.html" },
    { "src": "/questions", "dest": "/questions.html" },
    { "src": "/lessons", "dest": "/lessons.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
