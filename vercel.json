{
  "framework": null,
  "functions": {
    "api/chat.js":    { "memory": 512, "maxDuration": 60 },
    "api/webhook.js": { "memory": 256, "maxDuration": 30 },
    "api/auth.js":    { "memory": 256, "maxDuration": 15 },
    "api/export.js":  { "memory": 256, "maxDuration": 30 },
    "api/admin.js":   { "memory": 512, "maxDuration": 30 },
    "api/contact.js": { "memory": 128, "maxDuration": 10 },
    "api/email.js":   { "memory": 128, "maxDuration": 10 },
    "api/notes.js":   { "memory": 128, "maxDuration": 10 },
    "api/progress.js":{ "memory": 128, "maxDuration": 10 },
    "api/stripe.js":  { "memory": 128, "maxDuration": 10 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",    "value": "nosniff" },
        { "key": "X-Frame-Options",           "value": "DENY" },
        { "key": "X-XSS-Protection",          "value": "1; mode=block" },
        { "key": "Referrer-Policy",           "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",        "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    }
  ]
}
