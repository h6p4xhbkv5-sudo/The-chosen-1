# ══════════════════════════════════════════════════════════════
# LUMINA AI — Environment Variables
# Copy this file to .env.local for local development.
# Set all of these in Vercel → Settings → Environment Variables.
# ══════════════════════════════════════════════════════════════

# ─── Anthropic ────────────────────────────────────────────────
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── Supabase ─────────────────────────────────────────────────
# Get from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...   # service_role secret (never expose client-side)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...     # anon/public key (safe for frontend)

# ─── Site URL ─────────────────────────────────────────────────
# Your production domain. Used for email links, CORS origin, and Stripe redirects.
SITE_URL=https://your-project.vercel.app

# ─── Stripe ───────────────────────────────────────────────────
# Get from: dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...

# Price IDs from: Stripe → Products → [plan] → Pricing → copy price ID
STRIPE_PRICE_STUDENT=price_...
STRIPE_PRICE_HOMESCHOOL=price_...

# Webhook signing secret from: Stripe → Webhooks → [endpoint] → Signing secret
# Required events: checkout.session.completed, invoice.payment_succeeded,
#                  invoice.payment_failed, customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Email (Resend) ───────────────────────────────────────────
# Get from: resend.com → API Keys
# Add and verify your domain (luminaai.co.uk) in Resend before sending.
# Without this key, emails are skipped but the platform still works.
RESEND_API_KEY=re_...

# ─── Admin Dashboard ──────────────────────────────────────────
# Used to authenticate /admin.html — make this a long random string.
# Generate one: openssl rand -hex 32
ADMIN_SECRET_KEY=change-me-to-a-long-random-string
